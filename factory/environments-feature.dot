digraph EnvironmentsFeature {
  graph [
    goal="Add environment and attractor management that supports global and project scopes with project overrides, and move global secrets/environments/attractors access into the project context dropdown UX."
  ]

  start [shape=Mdiamond, label="Start"]
  plan [shape=box, label="Plan", prompt="Create an implementation-ready plan for environments + attractors scoping in Attractor Factory. Include data model, API contracts, UI/UX behavior, migration plan, and acceptance tests. Environments and attractors must both support global and project scopes with clear precedence and override rules. Update secrets UX so global secrets are managed from the project context dropdown instead of side-by-side panels. Apply the same dropdown pattern for global environments and global attractors."]
  implement [shape=box, label="Implement", prompt="Implement the planned scoped environments and scoped attractors features, plus global-in-dropdown UX updates for secrets, environments, and attractors across API, web app, and tests. Preserve existing behavior where not explicitly changed and include migration-safe defaults."]
  done [shape=Msquare, label="Done"]

  start -> plan
  plan -> implement
  implement -> done
}
